# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# GITHUB
GITHUB_TOKEN=
GITHUB_REPO=

# --- Email (Resend) ---
# API key de Resend (resend.com/api-keys). Sin ella, las notificaciones se omiten en silencio.
RESEND_API_KEY=
# Remitente. Modo pruebas: "Nombre <onboarding@resend.dev>".
# Producción: usa un dominio verificado, ej. "DYMMSA Cotizaciones <notifications@tu-dominio.com>".
RESEND_FROM_EMAIL="DYMMSA Cotizaciones <onboarding@resend.dev>"
# Destinatario de los avisos de aprobación (el buzón de los empleados DYMMSA).
# En modo pruebas de Resend DEBE ser el correo de tu propia cuenta Resend.
NOTIFICATION_EMAIL_TO=
# Opcional: a dónde van las respuestas si alguien contesta el aviso.
NOTIFICATION_REPLY_TO=
# URL base de la app para el link "Ver cotización" en el correo.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Módulo MCP interno (token compartido)
MCP_API_KEY=
