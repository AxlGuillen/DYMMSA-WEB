# ============================================================================
# Entorno de PRUEBAS contra el Supabase LOCAL (Fase B · E2E).
# Copia este archivo a `.env.test` (gitignoreado) y lo cargan los tests de
# integración (C1) y Playwright (C2). NO afecta `bun run dev` normal, que sigue
# usando `.env` (tu Supabase en la nube).
#
# Prerequisito: `bunx supabase start` corriendo.
# Las llaves de abajo son las DEMO deterministas del stack local (públicas, NO
# secretas — iguales en cualquier `supabase start`), por eso van en el ejemplo.
# ============================================================================

NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# Links de aprobación (la app arma /approve/[token] con esto)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Opcionales — se dejan VACÍOS a propósito en local ───────────────────────
# Correo de aprobación (Resend): aislado en try/catch, no rompe si falta.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
NOTIFICATION_EMAIL_TO=
NOTIFICATION_REPLY_TO=
# Módulo Tareas (GitHub Issues) y MCP interno: no se ejercitan en el E2E core.
GITHUB_TOKEN=
GITHUB_REPO=
MCP_API_KEY=

# ── Credenciales del usuario de prueba sembrado (supabase/seed.sql) ─────────
# Solo referencia para los tests; la app no lee estas vars.
# E2E_USER_EMAIL=test@dymmsa.local
# E2E_USER_PASSWORD=testpassword123
